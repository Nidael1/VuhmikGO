# VUHMIK — Variables de entorno de produccion
# Copiar como /opt/vuhmik/.env y llenar con valores reales
# NUNCA subir este archivo con valores reales a git

# Base de datos PostgreSQL
DATABASE_URL=postgres://vuhmik_user:CONTRASENA_SEGURA@localhost:5432/vuhmik_prod?sslmode=disable

# JWT — generar con: openssl rand -hex 64
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_DE_64_CHARS_MINIMO

# Redis
REDIS_URL=redis://localhost:6379

# Puerto del servidor (dejar en 8080, nginx hace el proxy)
PORT=8080

# Directorio de backups
BACKUP_DIR=/opt/vuhmik/backups
